# SubTrack deployment environment (copy to .env and fill in).
# NEVER commit .env — it is git-ignored.

# Postgres
POSTGRES_USER=subtrack
POSTGRES_PASSWORD=generate-a-strong-password
POSTGRES_DB=subtrack

# Secrets (generate strong randoms; never reuse dev values)
JWT_SECRET=replace-with-a-long-random-string
FERNET_KEY=replace-with-a-fernet-key
SECRET_KEY=replace-with-a-long-random-string

# CORS / origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:8080
# Frontend origin shown after Gmail OAuth (same as what users hit)
APP_URL=http://localhost:8080
# If the API lives on its own host, set this so the built frontend calls it directly.
VITE_API_BASE=

# LLM (OpenRouter) — REQUIRED for Gmail auto-import
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Comms
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google OAuth (required for Sign-in AND Gmail connect)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/oauth2callback

# Feature flags
GMAIL_INTEGRATION=false
